<Window x:Class="ASD.NES.WPF.Views.SettingsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ASD.NES.WPF.ViewModels"
        Title="Settings — keys (NES: D-pad, Select, Start, A, B)"
        Width="520" Height="480"
        WindowStartupLocation="CenterOwner"
        Background="#0F0F0F"
        ResizeMode="NoResize"
        Focusable="True"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#505050"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A3A3A"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Background" Value="#353535"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsKeyboardFocused" Value="True"/>
                        <Condition Property="IsMouseOver" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#3A3A3A"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Player labels centered above each gamepad; gamepads aligned to edges -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Width="100" HorizontalAlignment="Left">
                <TextBlock Text="Player 1" FontWeight="Bold" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                <Canvas Width="100" Height="70" Margin="0,4,0,0">
                    <Rectangle Canvas.Left="0" Canvas.Top="10" Width="100" Height="50" Fill="#1A1A1A" Stroke="#404040"/>
                    <Ellipse Canvas.Left="8" Canvas.Top="18" Width="28" Height="28" Fill="#333" Stroke="#505050"/>
                    <Rectangle Canvas.Left="14" Canvas.Top="22" Width="6" Height="16" Fill="#555"/>
                    <Rectangle Canvas.Left="22" Canvas.Top="14" Width="16" Height="6" Fill="#555"/>
                    <Ellipse Canvas.Left="62" Canvas.Top="22" Width="14" Height="14" Fill="#444" Stroke="#606060"/>
                    <Ellipse Canvas.Left="78" Canvas.Top="22" Width="14" Height="14" Fill="#444" Stroke="#606060"/>
                    <Rectangle Canvas.Left="38" Canvas.Top="38" Width="24" Height="8" Fill="#333" Stroke="#505050"/>
                </Canvas>
            </StackPanel>
            <StackPanel Grid.Column="1" Width="100" HorizontalAlignment="Right">
                <TextBlock Text="Player 2" FontWeight="Bold" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                <Canvas Width="100" Height="70" Margin="0,4,0,0">
                    <Rectangle Canvas.Left="0" Canvas.Top="10" Width="100" Height="50" Fill="#1A1A1A" Stroke="#404040"/>
                    <Ellipse Canvas.Left="8" Canvas.Top="18" Width="28" Height="28" Fill="#333" Stroke="#505050"/>
                    <Rectangle Canvas.Left="14" Canvas.Top="22" Width="6" Height="16" Fill="#555"/>
                    <Rectangle Canvas.Left="22" Canvas.Top="14" Width="16" Height="6" Fill="#555"/>
                    <Ellipse Canvas.Left="62" Canvas.Top="22" Width="14" Height="14" Fill="#444" Stroke="#606060"/>
                    <Ellipse Canvas.Left="78" Canvas.Top="22" Width="14" Height="14" Fill="#444" Stroke="#606060"/>
                    <Rectangle Canvas.Left="38" Canvas.Top="38" Width="24" Height="8" Fill="#333" Stroke="#505050"/>
                </Canvas>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Player 1: block aligned with gamepad (left); 96px between labels and buttons -->
            <StackPanel Grid.Column="0" Margin="0,0,12,0" HorizontalAlignment="Left">
                <Grid HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="96"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Left (D-pad)" HorizontalAlignment="Left"/>
                    <Button Grid.Row="0" Grid.Column="2" Content="{Binding P1Left}" Command="{Binding CaptureKey}" CommandParameter="P1_Left"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Up" HorizontalAlignment="Left"/>
                    <Button Grid.Row="1" Grid.Column="2" Content="{Binding P1Up}" Command="{Binding CaptureKey}" CommandParameter="P1_Up"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Right" HorizontalAlignment="Left"/>
                    <Button Grid.Row="2" Grid.Column="2" Content="{Binding P1Right}" Command="{Binding CaptureKey}" CommandParameter="P1_Right"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Down" HorizontalAlignment="Left"/>
                    <Button Grid.Row="3" Grid.Column="2" Content="{Binding P1Down}" Command="{Binding CaptureKey}" CommandParameter="P1_Down"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Select" HorizontalAlignment="Left"/>
                    <Button Grid.Row="4" Grid.Column="2" Content="{Binding P1Select}" Command="{Binding CaptureKey}" CommandParameter="P1_Select"/>
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Start" HorizontalAlignment="Left"/>
                    <Button Grid.Row="5" Grid.Column="2" Content="{Binding P1Start}" Command="{Binding CaptureKey}" CommandParameter="P1_Start"/>
                    <TextBlock Grid.Row="6" Grid.Column="0" Text="B" HorizontalAlignment="Left"/>
                    <Button Grid.Row="6" Grid.Column="2" Content="{Binding P1B}" Command="{Binding CaptureKey}" CommandParameter="P1_B"/>
                    <TextBlock Grid.Row="7" Grid.Column="0" Text="A" HorizontalAlignment="Left"/>
                    <Button Grid.Row="7" Grid.Column="2" Content="{Binding P1A}" Command="{Binding CaptureKey}" CommandParameter="P1_A"/>
                </Grid>
            </StackPanel>

            <!-- Player 2: block aligned with gamepad (right); 96px between buttons and labels -->
            <StackPanel Grid.Column="1" Margin="12,0,0,0" HorizontalAlignment="Right">
                <StackPanel.Resources>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="HorizontalContentAlignment" Value="Right"/>
                    </Style>
                </StackPanel.Resources>
                <Grid HorizontalAlignment="Right">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="96"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Button Grid.Row="0" Grid.Column="0" Content="{Binding P2Left}" Command="{Binding CaptureKey}" CommandParameter="P2_Left"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Left" HorizontalAlignment="Right"/>
                    <Button Grid.Row="1" Grid.Column="0" Content="{Binding P2Up}" Command="{Binding CaptureKey}" CommandParameter="P2_Up"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Up" HorizontalAlignment="Right"/>
                    <Button Grid.Row="2" Grid.Column="0" Content="{Binding P2Right}" Command="{Binding CaptureKey}" CommandParameter="P2_Right"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="Right" HorizontalAlignment="Right"/>
                    <Button Grid.Row="3" Grid.Column="0" Content="{Binding P2Down}" Command="{Binding CaptureKey}" CommandParameter="P2_Down"/>
                    <TextBlock Grid.Row="3" Grid.Column="2" Text="Down" HorizontalAlignment="Right"/>
                    <Button Grid.Row="4" Grid.Column="0" Content="{Binding P2Select}" Command="{Binding CaptureKey}" CommandParameter="P2_Select"/>
                    <TextBlock Grid.Row="4" Grid.Column="2" Text="Select" HorizontalAlignment="Right"/>
                    <Button Grid.Row="5" Grid.Column="0" Content="{Binding P2Start}" Command="{Binding CaptureKey}" CommandParameter="P2_Start"/>
                    <TextBlock Grid.Row="5" Grid.Column="2" Text="Start" HorizontalAlignment="Right"/>
                    <Button Grid.Row="6" Grid.Column="0" Content="{Binding P2B}" Command="{Binding CaptureKey}" CommandParameter="P2_B"/>
                    <TextBlock Grid.Row="6" Grid.Column="2" Text="B" HorizontalAlignment="Right"/>
                    <Button Grid.Row="7" Grid.Column="0" Content="{Binding P2A}" Command="{Binding CaptureKey}" CommandParameter="P2_A"/>
                    <TextBlock Grid.Row="7" Grid.Column="2" Text="A" HorizontalAlignment="Right"/>
                </Grid>
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="2" Foreground="#C0C0C0" Background="#252525" FontSize="11" Margin="0,8,0,0" Padding="6,4" Text="{Binding CapturingHint}"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Command="{Binding Cancel}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,8,0"/>
            <Button Content="Save" Command="{Binding SaveAndClose}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
        </StackPanel>
    </Grid>
</Window>
